<odoo>
    <data>
        <record id="pos_settings_view" model="ir.ui.view">
            <field name="name">pos.settings.view</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@id='pos_interface_section']" position="inside">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="invoice_auto_check"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="invoice_auto_check"/>
                            <div class="content-group" id="invoice_auto_check">
                                Enable to auto check invoice
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="close_session"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="close_session"/>
                            <div class="content-group" id="close_session">
                                Activate this option if you want to restrict the logout when there are invoices without an electronic signature.
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="qr_ticket"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="qr_ticket"/>
                            <div class="content-group" id="qr_ticket">
                                Activate this option if you want to show QR invoice in ticket.
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>